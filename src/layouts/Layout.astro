---
import '../styles/global.css';

interface Props {
	title: string;
	description?: string;
}

const {
	title,
	description = "Explore Kerala on a budget. The ultimate travel guide for students, solo travelers, and families under ₹2,000."
} = Astro.props;
---

<!doctype html>
<html lang="en">
<head>
	<meta charset="UTF-8" />
	<meta name="viewport" content="width=device-width" />
	<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
	<meta name="generator" content={Astro.generator} />
	<meta name="description" content={description} />
	<title>{title} | Explore Kerala</title>
</head>

<body>

<header class="sticky-header glass">
	<div class="container header-content">
		<a href="/" class="logo">Explore Kerala</a>

		<nav class="main-nav">
			<a href="/destinations">Destinations</a>
			<a href="/guides">Guides</a>
			<a href="/budget-calculator">Budget Calc</a>
		</nav>

		<div class="header-actions">
			<button id="theme-toggle" class="btn btn-icon" aria-label="Toggle Theme">
				🌙
			</button>
		</div>
	</div>
</header>

<main>
	<slot />
</main>

<footer class="glass mt-8 py-16">
	<div class="container footer-grid">
		<div class="footer-col">
			<h3>Explore Kerala</h3>
			<p>Your ultimate guide to traveling God's Own Country on a budget.</p>
		</div>

		<div class="footer-col">
			<h4>Links</h4>
			<ul>
				<li><a href="/about">About</a></li>
				<li><a href="/contact">Contact</a></li>
			</ul>
		</div>

		<div class="footer-col">
			<h4>Legal</h4>
			<ul>
				<li><a href="/privacy">Privacy Policy</a></li>
				<li><a href="/terms">Terms & Conditions</a></li>
			</ul>
		</div>

		<div class="footer-col">
			<h4>Newsletter</h4>
			<form class="newsletter-form">
				<input type="email" placeholder="Enter your email">
				<button class="btn btn-primary">Subscribe</button>
			</form>
		</div>
	</div>

	<div class="container text-center mt-8">
		<p>&copy; {new Date().getFullYear()} Explore Kerala. All rights reserved.</p>
	</div>
</footer>

<style>
.sticky-header{
	position:sticky;
	top:0;
	z-index:100;
	padding:1rem 0;
}

.header-content{
	display:flex;
	justify-content:space-between;
	align-items:center;
}

.logo{
	font-size:1.5rem;
	font-weight:700;
	color:var(--primary);
}

.main-nav{
	display:flex;
	gap:1.5rem;
}

.main-nav a{
	color:var(--text-color);
	font-weight:500;
}

.main-nav a:hover{
	color:var(--primary);
}

.btn-icon{
	background:transparent;
	border:none;
	cursor:pointer;
	font-size:1.2rem;
}

.footer-grid{
	display:grid;
	grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
	gap:2rem;
}

.footer-col ul{
	list-style:none;
	padding:0;
}

.footer-col li{
	margin:.5rem 0;
}

.newsletter-form{
	display:flex;
	flex-direction:column;
	gap:.75rem;
}

.newsletter-form input{
	padding:.75rem;
	border:1px solid var(--border-color);
	border-radius:6px;
}
</style>

</body>
</html>