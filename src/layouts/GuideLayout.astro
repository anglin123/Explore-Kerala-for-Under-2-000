---
import Layout from './Layout.astro';
import '../styles/global.css';

const { frontmatter } = Astro.props;
---

<Layout title={frontmatter.title} description={frontmatter.description}>
	<!-- Minimalist Guide Hero -->
	<section class="guide-hero bg-light text-center py-16">
		<div class="container hero-content">
			<span class="category-badge">{frontmatter.category}</span>
			<h1 class="hero-title">{frontmatter.title}</h1>
			<p class="hero-subtitle text-light">{frontmatter.description}</p>
			<div class="author-meta mt-4 text-light">
				<span>By {frontmatter.author}</span> | <span>{frontmatter.date}</span> | <span>{frontmatter.readTime}</span>
			</div>
			{frontmatter.heroImage && (
				<img src={frontmatter.heroImage} alt={frontmatter.title} class="hero-image shadow-md mt-8" loading="lazy" />
			)}
		</div>
	</section>

	<div class="container guide-layout mt-8 mb-8">
		<!-- Sidebar Share/TOC -->
		<aside class="sidebar sticky-sidebar">
			<div class="card p-4 shadow-sm mb-4">
				<h3 style="margin-bottom: 0.5rem; font-size: 1rem;">Share</h3>
				<div class="social-share">
					<a href="#" class="share-link">Facebook</a>
					<a href="#" class="share-link">Twitter</a>
					<a href="#" class="share-link">WhatsApp</a>
				</div>
			</div>
			
			<div class="card p-4 shadow-sm">
				<h3 style="margin-bottom: 0.5rem; font-size: 1rem;">Table of Contents</h3>
				<nav class="toc">
					<a href="#overview">Overview</a>
					<a href="#itinerary">Itinerary</a>
					<a href="#budget-breakdown">Budget Breakdown</a>
					<a href="#tips">Pro Tips</a>
				</nav>
			</div>
		</aside>

		<!-- Main Content -->
		<article class="content p-8 card shadow-sm">
			<slot />
		</article>
	</div>
</Layout>

<style>
	.bg-light {
		background-color: var(--secondary-bg);
		border-bottom: 1px solid var(--border-color);
	}
	.category-badge {
		background: var(--primary);
		color: white;
		padding: 0.25rem 1rem;
		border-radius: 4px;
		font-weight: 600;
		font-size: 0.85rem;
		text-transform: uppercase;
		display: inline-block;
		margin-bottom: 1rem;
	}
	.hero-title {
		font-size: 3rem;
		margin-bottom: 0.5rem;
		color: var(--text-color);
		max-width: 800px;
		margin-left: auto;
		margin-right: auto;
	}
	.hero-subtitle {
		font-size: 1.25rem;
		max-width: 700px;
		margin: 1rem auto;
	}
	.author-meta {
		font-size: 0.9rem;
	}
	.hero-image {
		width: 100%;
		max-height: 450px;
		object-fit: cover;
		border-radius: 8px;
	}
	.guide-layout {
		display: grid;
		grid-template-columns: 250px 1fr;
		gap: 2rem;
	}
	.sticky-sidebar {
		position: sticky;
		top: 100px;
		align-self: start;
	}
	.p-4 { padding: 1rem; }
	.p-8 { padding: 2rem; }
	
	.social-share {
		display: flex;
		flex-direction: column;
		gap: 0.25rem;
	}
	.share-link {
		color: var(--text-light);
		font-size: 0.9rem;
	}
	.share-link:hover {
		color: var(--primary);
	}
	.toc {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}
	.toc a {
		color: var(--text-light);
		font-size: 0.9rem;
	}
	.toc a:hover {
		color: var(--primary);
	}
	
	.content :global(h2) {
		margin-top: 2.5rem;
		margin-bottom: 1rem;
		color: var(--primary);
		border-bottom: 1px solid var(--border-color);
		padding-bottom: 0.5rem;
	}
	.content :global(h3) {
		margin-top: 1.5rem;
		margin-bottom: 0.75rem;
	}
	.content :global(ul) {
		margin-left: 1.5rem;
		margin-bottom: 1.5rem;
		color: var(--text-color);
	}
	.content :global(p) {
		margin-bottom: 1.5rem;
		color: var(--text-color);
	}
	
	@media (max-width: 768px) {
		.guide-layout {
			grid-template-columns: 1fr;
		}
		.sticky-sidebar {
			position: static;
		}
	}
</style>
