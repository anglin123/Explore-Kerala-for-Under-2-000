---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
import BudgetCalculator from '../components/BudgetCalculator.astro';

const featuredDestinations = [
  {
    name: 'Munnar',
    title: 'Tea Gardens & Misty Hills',
    image: 'https://images.unsplash.com/photo-1593693397690-362cb9666c6c?auto=format&fit=crop&w=800&q=80'
  },
  {
    name: 'Alleppey',
    title: 'Backwater Houseboats',
    image: 'https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?auto=format&fit=crop&w=800&q=80'
  },
  {
    name: 'Varkala',
    title: 'Stunning Cliff Beaches',
    image: 'https://images.unsplash.com/photo-1590523277543-a94d2e4eb00b?auto=format&fit=crop&w=800&q=80'
  }
];

const budgetGuides = [
  {
    title: 'Explore Kerala for Under ₹2,000',
    desc: 'The ultimate guide to backpacking Kerala on a shoestring budget.',
    link: '/guides/under-2000'
  },
  {
    title: 'Weekend Trip Under ₹1,500',
    desc: "Quick getaways that won't break the bank.",
    link: '/guides/weekend-1500'
  },
  {
    title: 'Cheap Kerala Honeymoon',
    desc: "Romantic experiences in God's Own Country on a budget.",
    link: '/guides/cheap-honeymoon'
  }
];
---

<Layout title="Home">

<section class="hero">
  <div class="hero-bg"></div>

  <div class="container hero-content">
    <h1>Experience Kerala on a Budget</h1>

    <p>
      Discover hidden gems, beautiful beaches and hill stations
      without spending a fortune.
    </p>

    <div class="buttons">
      <a href="/destinations">Explore Destinations</a>
      <a href="/budget-calculator">Budget Calculator</a>
    </div>
  </div>
</section>

<section class="container">
  <h2>Trending Destinations</h2>

  <div class="destination-grid">
    {
      featuredDestinations.map((d) => (
        <a href={`/destinations/${d.name.toLowerCase()}`}>
          <img src={d.image} alt={d.name} loading="lazy" />
          <h3>{d.name}</h3>
          <p>{d.title}</p>
        </a>
      ))
    }
  </div>
</section>

<section class="container">
  <h2>Top Budget Guides</h2>

  <div class="guide-grid">
    {
      budgetGuides.map((g) => (
        <div>
          <h3>{g.title}</h3>
          <p>{g.desc}</p>
          <a href={g.link}>Read Guide →</a>
        </div>
      ))
    }
  </div>
</section>

<section class="container">
  <h2>Plan Your Trip Budget</h2>
  <BudgetCalculator />
</section>

</Layout>