---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';

// Components we will build later
// import InteractiveMap from '../components/InteractiveMap.astro';
import BudgetCalculator from '../components/BudgetCalculator.astro';

const featuredDestinations = [
	{ name: 'Munnar', title: 'Tea Gardens & Misty Hills', image: 'https://images.unsplash.com/photo-1593693397690-362cb9666c6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
	{ name: 'Alleppey', title: 'Backwater Houseboats', image: 'https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
	{ name: 'Varkala', title: 'Stunning Cliff Beaches', image: 'https://images.unsplash.com/photo-1590523277543-a94d2e4eb00b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
];

const budgetGuides = [
	{ title: 'Explore Kerala for Under ₹2,000', desc: 'The ultimate guide to backpacking Kerala on a shoestring budget.', link: '/guides/under-2000' },
	{ title: 'Weekend Trip Under ₹1,500', desc: 'Quick getaways that won\'t break the bank.', link: '/guides/weekend-1500' },
	{ title: 'Cheap Kerala Honeymoon', desc: 'Romantic experiences in God\'s own country on a budget.', link: '/guides/cheap-honeymoon' },
];
---

<Layout title="Home">
	<!-- Hero Section -->
	<section class="hero relative">
		<div class="hero-bg"></div>
		<div class="container hero-content text-center reveal">
			<h1 class="hero-title">Experience Kerala on a Budget</h1>
			<p class="hero-subtitle">Discover hidden gems, stunning landscapes, and rich culture without breaking the bank. Your ultimate guide to traveling Kerala for under ₹2,000.</p>
			<div class="mt-8">
				<a href="/destinations" class="btn btn-primary">Explore Destinations</a>
				<a href="/budget-calculator" class="btn btn-accent" style="margin-left: 1rem;">Calculate Budget</a>
			</div>
		</div>
	</section>

	<!-- Featured Destinations -->
	<section class="py-16 container">
		<h2 class="text-center mb-8 reveal">Trending Destinations</h2>
		<div class="destination-grid">
			{featuredDestinations.map(dest => (
				<a href={`/destinations/${dest.name.toLowerCase()}`} class="destination-card glass reveal">
					<img src={dest.image} alt={dest.name} class="destination-img" loading="lazy" />
					<div class="destination-info">
						<h3>{dest.name}</h3>
						<p>{dest.title}</p>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- Top Budget Trips -->
	<section class="py-16 container" style="background-color: var(--card-bg); border-radius: 20px;">
		<h2 class="text-center mb-8 reveal">Top Budget Guides</h2>
		<div class="guide-grid">
			{budgetGuides.map(guide => (
				<div class="guide-card glass reveal">
					<h3>{guide.title}</h3>
					<p>{guide.desc}</p>
					<a href={guide.link} class="read-more mt-4">Read Guide &rarr;</a>
				</div>
			))}
		</div>
	</section>

	<!-- Travel Cost Calculator Section -->
	<section class="py-16 container">
		<h2 class="text-center mb-8 reveal">Plan Your Trip Budget</h2>
		<BudgetCalculator />
	</section>

	<!-- Interactive Map Section Placeholder -->
	<section class="py-16 container text-center reveal">
		<h2 class="mb-4">Kerala District Explorer</h2>
		<p class="mb-8">Click on a district to discover budget travel tips, hidden gems, and itineraries.</p>
		<div class="glass" style="height: 400px; display: flex; align-items: center; justify-content: center; border-radius: 12px;">
			<p>Interactive Map Component Loading...</p>
			<!-- <InteractiveMap /> -->
		</div>
	</section>
</Layout>

<style>
	.hero {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		color: white;
		position: relative;
		overflow: hidden;
	}
	.hero-bg {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(rgba(0,0,0,0.5), rgba(0,0,0,0.7)), url('https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?ixlib=rb-4.0.3&auto=format&fit=crop&w=1920&q=80') center/cover;
		z-index: -1;
	}
	.hero-content {
		max-width: 800px;
	}
	.hero-title {
		font-size: 4rem;
		margin-bottom: 1rem;
		text-shadow: 2px 2px 4px rgba(0,0,0,0.5);
	}
	.hero-subtitle {
		font-size: 1.25rem;
		opacity: 0.9;
	}

	.destination-grid, .guide-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.destination-card {
		border-radius: 12px;
		overflow: hidden;
		display: block;
		color: var(--text-color);
		position: relative;
	}
	.destination-card:hover .destination-img {
		transform: scale(1.05);
	}
	.destination-img {
		width: 100%;
		height: 250px;
		object-fit: cover;
		transition: transform var(--transition-normal);
	}
	.destination-info {
		padding: 1.5rem;
	}

	.guide-card {
		padding: 2rem;
		border-radius: 12px;
	}
	.read-more {
		display: inline-block;
		font-weight: 600;
	}
	
	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}
	}
</style>
