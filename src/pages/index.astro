---
import Layout from '../layouts/Layout.astro';

const featuredArticles = [
	{ title: 'Best Budget Trips in Kerala', desc: 'Top 5 itineraries for under ₹2,000.', link: '/guides/best-budget-trips', img: 'https://images.unsplash.com/photo-1593693397690-362cb9666c6c?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
	{ title: 'Hidden Places in Kerala', desc: 'Secret spots untouched by mass tourism.', link: '/guides/hidden-places', img: 'https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
	{ title: 'Kerala Bus Travel Guide', desc: 'How to use KSRTC to travel on a shoestring.', link: '/guides/bus-travel', img: 'https://images.unsplash.com/photo-1590523277543-a94d2e4eb00b?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' },
];

const popularDestinations = ['Munnar', 'Alleppey', 'Wayanad', 'Varkala', 'Fort Kochi', 'Vagamon'];
---

<Layout title="Home">
	<!-- Minimalist Hero Section -->
	<section class="hero py-16 text-center">
		<div class="container hero-content">
			<h1 class="hero-title">Explore Kerala on a Budget</h1>
			<p class="hero-subtitle text-light mb-8">Simple, affordable, and authentic travel guides for your next ₹2,000 adventure.</p>
			<img src="https://images.unsplash.com/photo-1602216056096-3b40cc0c9944?ixlib=rb-4.0.3&auto=format&fit=crop&w=1200&q=80" alt="Kerala Backwaters" class="hero-image shadow-md" loading="lazy" />
		</div>
	</section>

	<!-- Welcome Section -->
	<section class="welcome bg-light py-16">
		<div class="container text-center">
			<h2 class="mb-4">Welcome to Explore Kerala</h2>
			<p class="text-light" style="max-width: 700px; margin: 0 auto;">We believe that experiencing the beauty of God's Own Country shouldn't require a luxury budget. From hidden backwaters to misty tea gardens, we provide actionable tips to help you travel for under ₹2,000 a day.</p>
		</div>
	</section>

	<!-- Featured Articles -->
	<section class="py-16 container">
		<h2 class="text-center mb-8">Featured Articles</h2>
		<div class="article-grid">
			{featuredArticles.map(article => (
				<a href={article.link} class="card">
					<img src={article.img} alt={article.title} class="card-img" loading="lazy" />
					<div class="card-content">
						<h3>{article.title}</h3>
						<p class="text-light">{article.desc}</p>
						<span class="read-more mt-4">Read Article &rarr;</span>
					</div>
				</a>
			))}
		</div>
	</section>

	<!-- Popular Destinations -->
	<section class="py-16 container text-center">
		<h2 class="mb-8">Popular Destinations</h2>
		<div class="tags-grid">
			{popularDestinations.map(dest => (
				<a href={`/destinations/${dest.toLowerCase().replace(' ', '-')}`} class="tag-pill">{dest}</a>
			))}
		</div>
	</section>

	<!-- Newsletter -->
	<section class="newsletter-section py-16 bg-light text-center">
		<div class="container" style="max-width: 600px;">
			<h2 class="mb-4">Get Budget Travel Tips</h2>
			<p class="text-light mb-4">Subscribe to our newsletter for the latest hidden gems and budget itineraries.</p>
			<form class="newsletter-form">
				<input type="email" placeholder="Your email address" required />
				<button type="submit" class="btn btn-primary">Subscribe</button>
			</form>
		</div>
	</section>
</Layout>

<style>
	.hero-title {
		font-size: 3.5rem;
		color: var(--primary);
	}
	.hero-subtitle {
		font-size: 1.25rem;
		max-width: 600px;
		margin-left: auto;
		margin-right: auto;
	}
	.hero-image {
		width: 100%;
		max-height: 500px;
		object-fit: cover;
		border-radius: 12px;
	}
	
	.bg-light {
		background-color: var(--secondary-bg);
	}

	.article-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}
	.card {
		display: flex;
		flex-direction: column;
		color: var(--text-color);
	}
	.card-img {
		width: 100%;
		height: 200px;
		object-fit: cover;
	}
	.card-content {
		padding: 1.5rem;
	}
	.read-more {
		display: inline-block;
		font-weight: 600;
		color: var(--primary);
		font-size: 0.9rem;
	}

	.tags-grid {
		display: flex;
		flex-wrap: wrap;
		justify-content: center;
		gap: 1rem;
	}
	.tag-pill {
		padding: 0.5rem 1.5rem;
		border-radius: 9999px;
		background: white;
		border: 1px solid var(--border-color);
		color: var(--text-color);
		font-weight: 500;
	}
	.tag-pill:hover {
		border-color: var(--primary);
		color: var(--primary);
	}

	.newsletter-form {
		display: flex;
		gap: 0.5rem;
	}
	.newsletter-form input {
		flex: 1;
		padding: 0.75rem;
		border-radius: 4px;
		border: 1px solid var(--border-color);
	}
	
	@media (max-width: 768px) {
		.hero-title {
			font-size: 2.5rem;
		}
		.newsletter-form {
			flex-direction: column;
		}
	}
</style>
